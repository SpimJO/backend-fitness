# Copy to .env — never commit .env

# Use Session pooler from Supabase → Connect (NOT the direct db.* host on Windows).
# Example shape (copy YOUR exact URI from the dashboard):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require

SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string
GEMINI_API_KEY=
